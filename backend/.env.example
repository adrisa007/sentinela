# Ambiente de execução (development, production, test)
NODE_ENV=production

# Conexão com o banco Postgres (usar SSL em produção)
DATABASE_URL=postgresql://user:pass@host:5432/db?sslmode=require

# JWT: usar chave com alta entropia (>= 32 chars)
JWT_SECRET=sua_chave_secreta_de_512_bits_aqui
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=30d

# Cookies de sessão/CSRF
COOKIE_SECRET=sua_chave_cookie_256_bits_aqui

# Criptografia simétrica (AES-256-GCM), chave em hex de 64 chars
ENCRYPTION_KEY=sua_chave_aes_256_gcm_64_hex_aqui

# URLs públicas
FRONTEND_URL=https://sentinela-opal-seven.vercel.app
API_URL=https://opal.vercel.app

# Rate limit (TTL em ms e limites por janela)
THROTTLE_TTL=60000
THROTTLE_LIMIT=300
THROTTLE_LIMIT_LOGIN=10

# Vercel Blob (armazenamento)
VERCEL_BLOB_TOKEN=seu_token_blob_aqui

# Observabilidade
SENTRY_DSN=https://sua_dsn@sentry.io/123456